---
interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Navegación" class="relative z-10 py-4">
  <div class="container mx-auto px-6">
    <ol
      class="inline-flex items-center space-x-1 md:space-x-3 bg-surface-card/40 backdrop-blur-xl border border-primary-500/10 px-5 py-2.5 rounded-2xl shadow-xl shadow-primary-500/5"
    >
      {
        items.map((item, index) => (
          <li class="inline-flex items-center">
            {index === 0 ? (
              <a
                href={item.url || "/"}
                class="inline-flex items-center text-xs md:text-sm font-medium text-muted hover:text-primary-500 transition-all duration-300"
              >
                <svg
                  class="w-4 h-4 mr-2.5 text-primary-500/80"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
                </svg>
                {item.name}
              </a>
            ) : (
              <div class="flex items-center">
                <svg
                  class="w-5 h-5 text-primary-500/30 font-thin mx-1"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                    clip-rule="evenodd"
                  />
                </svg>
                {item.url ? (
                  <a
                    href={item.url}
                    class="ml-1 md:ml-2 text-xs md:text-sm font-medium text-muted hover:text-primary-500 transition-all duration-300"
                  >
                    {item.name}
                  </a>
                ) : (
                  <span
                    class="ml-1 md:ml-2 text-xs md:text-sm font-bold text-primary-500 uppercase tracking-widest"
                    aria-current="page"
                  >
                    {item.name}
                  </span>
                )}
              </div>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</nav>
