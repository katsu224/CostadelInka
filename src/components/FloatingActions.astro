---
// src/components/FloatingActions.astro
// Floating action buttons for WhatsApp and Booking that persist across the site

const whatsappSjNumber = "51920585300";
const whatsappMessage =
  "Hola, me gustaría recibir más información sobre las habitaciones.";
const whatsappLink = `https://wa.me/${whatsappSjNumber}?text=${encodeURIComponent(whatsappMessage)}`;
const bookingLink = "https://www.booking.com/hotel/pe/costa-del-inka.es.html";
---

<div class="fixed bottom-6 right-6 flex flex-col gap-4 z-40">
  <!-- Booking Button -->
  <a
    href={bookingLink}
    target="_blank"
    rel="noopener noreferrer"
    class="group relative flex items-center justify-center w-14 h-14 bg-[#003580] text-white rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
    aria-label="Reservar en Booking.com"
  >
    <!-- Booking Icon (B/Bed) -->
    <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M7 19h10V4H7v15zm-5-2h4v2H2v-2zm18 0h4v2h-4v-2zM3 5h4V3H3v2zm18 0h-4V3h4v2z"
        opacity="0.5"></path>
      <path
        d="M12 7c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-3 7h6v-2H9v2zm8-11H7v15h10V3z"
      ></path>
      <text
        x="12"
        y="16.5"
        font-family="Arial, sans-serif"
        font-weight="bold"
        font-size="12"
        fill="white"
        text-anchor="middle">B.</text
      >
    </svg>

    <!-- Tooltip -->
    <span
      class="absolute right-full mr-4 top-1/2 -translate-y-1/2 px-3 py-1.5 bg-dark-900/90 backdrop-blur-sm text-white text-sm font-semibold rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 whitespace-nowrap shadow-md pointer-events-none"
    >
      Reservar ahora
      <!-- Tooltip Triangle -->
      <span
        class="absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 bg-dark-900/90 rotate-45"
      ></span>
    </span>
  </a>

  <!-- WhatsApp Button -->
  <a
    href={whatsappLink}
    target="_blank"
    rel="noopener noreferrer"
    class="group relative flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
    aria-label="Contactar por WhatsApp"
  >
    <!-- WhatsApp Icon -->
    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
      ></path>
    </svg>

    <!-- Tooltip -->
    <span
      class="absolute right-full mr-4 top-1/2 -translate-y-1/2 px-3 py-1.5 bg-dark-900/90 backdrop-blur-sm text-white text-sm font-semibold rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 whitespace-nowrap shadow-md pointer-events-none"
    >
      Contáctanos
      <!-- Tooltip Triangle -->
      <span
        class="absolute top-1/2 -right-1.5 -translate-y-1/2 w-3 h-3 bg-dark-900/90 rotate-45"
      ></span>
    </span>
  </a>
</div>
