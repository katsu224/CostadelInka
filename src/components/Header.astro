---
const menuItems = [
  { text: "Inicio", href: "/" },
  { text: "Nosotros", href: "/about" },
  { text: "Habitaciones", href: "/room" },
  { text: "Servicios", href: "/service" },
  { text: "Galería", href: "/gallery" },
  { text: "Contacto", href: "/contact" },
];
---

<header
  id="main-header"
  class="fixed w-full top-0 z-50 backdrop-blur-md border-b border-white/10 transition-all duration-300"
  style="background:rgba(26,26,26,0.8);"
>
  <div class="container mx-auto px-6 flex justify-between items-center transition-all duration-300" id="header-inner" style="padding-top:1rem;padding-bottom:1rem;">
    <a href="/" class="flex items-center gap-2 logo-animate">
      <div class="flex flex-col">
        <span
          class="font-heading text-2xl font-bold text-primary-500 tracking-wider"
          >COSTA</span
        >
        <span class="font-heading text-xl text-white tracking-widest -mt-2"
          >DEL INKA</span
        >
      </div>
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden md:flex items-center gap-8">
      {
        menuItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-white/80 hover:text-primary-400 transition-colors uppercase tracking-wide"
          >
            {item.text}
          </a>
        ))
      }

      <!-- Dark/Light Mode Toggle -->
      <button
        id="theme-toggle"
        class="relative w-14 h-7 bg-dark-700 rounded-full flex items-center px-1 cursor-pointer border border-white/10 hover:border-primary-500/50"
        aria-label="Cambiar modo claro/oscuro"
        title="Cambiar modo claro/oscuro"
      >
        <span
          class="text-xs absolute left-1.5 top-1/2 -translate-y-1/2 pointer-events-none select-none"
          aria-hidden="true">☀️</span
        >
        <span
          class="text-xs absolute right-1.5 top-1/2 -translate-y-1/2 pointer-events-none select-none"
          aria-hidden="true">🌙</span
        >
        <span
          id="toggle-indicator"
          class="w-5 h-5 bg-primary-500 rounded-full shadow-md z-10"
          style="transition: transform 0.3s ease;"></span>
      </button>

      <a
        href="/contact"
        class="px-6 py-2 bg-primary-700 text-white font-medium rounded-sm hover:bg-primary-800 transition-all uppercase text-sm tracking-wide"
      >
        Reservar
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <div class="md:hidden flex items-center gap-3">
      <button
        id="theme-toggle-mobile-btn"
        class="w-9 h-9 flex items-center justify-center rounded-full bg-white/10 border border-white/20 hover:border-primary-500/50 hover:bg-white/20 transition-all"
        aria-label="Cambiar modo claro/oscuro"
      >
        <svg id="mobile-icon-sun" class="w-4.5 h-4.5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg id="mobile-icon-moon" class="w-4.5 h-4.5 text-primary-400 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>
      <button
        id="menu-toggle"
        class="text-white hover:text-primary-400 transition-colors"
        aria-label="Abrir menú de navegación"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-dark-900 z-50 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col justify-center items-center gap-8"
>
  <button
    id="menu-close"
    class="absolute top-6 right-6 text-white hover:text-primary-400"
    aria-label="Cerrar menú"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-10 h-10"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  {
    menuItems.map((item) => (
      <a
        href={item.href}
        class="text-3xl font-heading text-white hover:text-primary-500 transition-colors"
      >
        {item.text}
      </a>
    ))
  }
</div>

<script is:inline>
  (function () {
    // === Header shrink on scroll ===
    var headerInner = document.getElementById('header-inner');
    var header = document.getElementById('main-header');
    var scrolled = false;

    function onScroll() {
      var isScrolled = window.scrollY > 60;
      if (isScrolled === scrolled) return;
      scrolled = isScrolled;
      if (isScrolled) {
        headerInner.style.paddingTop = '0.4rem';
        headerInner.style.paddingBottom = '0.4rem';
        header.style.background = 'rgba(26,26,26,0.95)';
      } else {
        headerInner.style.paddingTop = '1rem';
        headerInner.style.paddingBottom = '1rem';
        header.style.background = 'rgba(26,26,26,0.8)';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // === Dark mode toggle ===
    function isDarkActive() {
      return document.documentElement.classList.contains("is-dark");
    }

    function setDarkMode(isDark) {
      document.documentElement.classList.toggle("is-dark", isDark);
      document.documentElement.classList.add("theme-ready");
      localStorage.setItem("hotel-theme-mode", isDark ? "dark" : "light");
      updateToggleUI(isDark);
    }

    function updateToggleUI(isDark) {
      var indicator = document.getElementById("toggle-indicator");
      var sunIcon = document.getElementById("mobile-icon-sun");
      var moonIcon = document.getElementById("mobile-icon-moon");

      if (indicator) {
        indicator.style.transform = isDark
          ? "translateX(1.75rem)"
          : "translateX(0)";
      }
      if (sunIcon && moonIcon) {
        sunIcon.classList.toggle("hidden", isDark);
        moonIcon.classList.toggle("hidden", !isDark);
      }
    }

    var isDark = isDarkActive();
    updateToggleUI(isDark);

    var toggle = document.getElementById("theme-toggle");
    var toggleMobile = document.getElementById("theme-toggle-mobile-btn");

    function handleToggle() {
      setDarkMode(!isDarkActive());
    }

    if (toggle) toggle.addEventListener("click", handleToggle);
    if (toggleMobile) toggleMobile.addEventListener("click", handleToggle);

    // === Mobile menu ===
    var menuToggle = document.getElementById("menu-toggle");
    var menuClose = document.getElementById("menu-close");
    var mobileMenu = document.getElementById("mobile-menu");

    function toggleMenuFn() {
      if (mobileMenu) mobileMenu.classList.toggle("translate-x-full");
      document.body.classList.toggle("overflow-hidden");
    }

    if (menuToggle) menuToggle.addEventListener("click", toggleMenuFn);
    if (menuClose) menuClose.addEventListener("click", toggleMenuFn);
  })();
</script>
