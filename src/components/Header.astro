---
const menuItems = [
  { text: "Inicio", href: "/" },
  { text: "Nosotros", href: "/about" },
  { text: "Habitaciones", href: "/room" },
  { text: "Servicios", href: "/service" },
  { text: "Instalaciones", href: "/gallery" },
  { text: "Contacto", href: "/contact" },
];
---

<header
  class="fixed w-full top-0 z-50 bg-dark-900/80 backdrop-blur-md border-b border-white/10"
>
  <div class="container mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-2 logo-animate">
      <div class="flex flex-col">
        <span
          class="font-heading text-2xl font-bold text-primary-500 tracking-wider"
          >COSTA</span
        >
        <span class="font-heading text-xl text-white tracking-widest -mt-2"
          >DEL INKA</span
        >
      </div>
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden md:flex items-center gap-8">
      {
        menuItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-white/80 hover:text-primary-400 transition-colors uppercase tracking-wide"
          >
            {item.text}
          </a>
        ))
      }

      <!-- Dark/Light Mode Toggle -->
      <button
        id="theme-toggle"
        class="relative w-14 h-7 bg-dark-700 rounded-full flex items-center px-1 cursor-pointer border border-white/10 hover:border-primary-500/50"
        aria-label="Cambiar modo claro/oscuro"
        title="Cambiar modo claro/oscuro"
      >
        <span
          class="text-xs absolute left-1.5 top-1/2 -translate-y-1/2 pointer-events-none select-none"
          aria-hidden="true">☀️</span
        >
        <span
          class="text-xs absolute right-1.5 top-1/2 -translate-y-1/2 pointer-events-none select-none"
          aria-hidden="true">🌙</span
        >
        <span
          id="toggle-indicator"
          class="w-5 h-5 bg-primary-500 rounded-full shadow-md z-10"
          style="transition: transform 0.3s ease;"></span>
      </button>

      <a
        href="/contact"
        class="px-6 py-2 bg-primary-600 text-white font-medium rounded-sm hover:bg-primary-700 transition-all uppercase text-sm tracking-wide"
      >
        Reservar
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <div class="md:hidden flex items-center gap-4">
      <button
        id="theme-toggle-mobile-btn"
        class="text-white/80 hover:text-primary-400 transition-colors"
        aria-label="Cambiar modo claro/oscuro"
      >
        <span id="mobile-toggle-icon-header" class="text-lg">☀️</span>
      </button>
      <button
        id="menu-toggle"
        class="text-white hover:text-primary-400 transition-colors"
        aria-label="Abrir menú de navegación"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-8 h-8"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-dark-900 z-50 transform translate-x-full transition-transform duration-300 md:hidden flex flex-col justify-center items-center gap-8"
>
  <button
    id="menu-close"
    class="absolute top-6 right-6 text-white hover:text-primary-400"
    aria-label="Cerrar menú"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-10 h-10"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  {
    menuItems.map((item) => (
      <a
        href={item.href}
        class="text-3xl font-heading text-white hover:text-primary-500 transition-colors"
      >
        {item.text}
      </a>
    ))
  }
</div>

<script is:inline>
  (function () {
    // === Dark mode toggle ===
    function isDarkActive() {
      return document.documentElement.classList.contains("is-dark");
    }

    function setDarkMode(isDark) {
      document.documentElement.classList.toggle("is-dark", isDark);

      // Habilitar transiciones suaves después del primer toggle
      document.documentElement.classList.add("theme-ready");

      // Guardar preferencia global
      localStorage.setItem("hotel-theme-mode", isDark ? "dark" : "light");

      // Actualizar UI del toggle
      updateToggleUI(isDark);
    }

    function updateToggleUI(isDark) {
      var indicator = document.getElementById("toggle-indicator");
      var mobileIcon = document.getElementById("mobile-toggle-icon-header");

      if (indicator) {
        indicator.style.transform = isDark
          ? "translateX(1.75rem)"
          : "translateX(0)";
      }
      if (mobileIcon) {
        mobileIcon.textContent = isDark ? "🌙" : "☀️";
      }
    }

    // Sincronizar UI del toggle con el estado actual
    var isDark = isDarkActive();
    updateToggleUI(isDark);

    // Event listeners
    var toggle = document.getElementById("theme-toggle");
    var toggleMobile = document.getElementById("theme-toggle-mobile-btn");

    function handleToggle() {
      setDarkMode(!isDarkActive());
    }

    if (toggle) toggle.addEventListener("click", handleToggle);
    if (toggleMobile) toggleMobile.addEventListener("click", handleToggle);

    // === Mobile menu ===
    var menuToggle = document.getElementById("menu-toggle");
    var menuClose = document.getElementById("menu-close");
    var mobileMenu = document.getElementById("mobile-menu");

    function toggleMenu() {
      if (mobileMenu) mobileMenu.classList.toggle("translate-x-full");
      document.body.classList.toggle("overflow-hidden");
    }

    if (menuToggle) menuToggle.addEventListener("click", toggleMenu);
    if (menuClose) menuClose.addEventListener("click", toggleMenu);
  })();
</script>
