---
import type { Theme } from '../layouts/MainLayout.astro';

interface Props {
  theme?: Theme;
}

const { theme = 'default' } = Astro.props;

import heroBg from '../assets/hero.webp';

const experiences = [
  {
    title: "Habitaciones",
    image: "/images/rooms/habitacion-doble.webp",
    href: "/room",
  },
  {
    title: "Restaurante",
    image: "/images/services/restaurante-plato.webp",
    href: "/restaurant",
  },
  {
    title: "Terraza",
    image: "/images/services/terraza-exterior.webp",
    href: "/terraza",
  },
];
---

<section class="relative h-screen flex flex-col items-center justify-center overflow-hidden bg-dark-900">
  <!-- Image Background -->
  <div class="absolute inset-0 z-0">
    <img src={heroBg.src} alt="Hero Image" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/40"></div>
  </div>

  <!-- Centered Content (absolute so pills don't push it up)-->
  <div class="absolute inset-0 z-10 flex items-center justify-center" style="padding-bottom: 180px;">
    <div class="container mx-auto px-6 text-center">
      <div class="mb-6 animate-fade-in-up">
        <span class="inline-block py-1 px-3 border border-white/40 rounded-full bg-white/10 backdrop-blur-sm text-white text-sm tracking-[0.2em] uppercase mb-4">
          Nuevo Chimbote, Perú
        </span>
        <h1 class="font-heading text-3xl md:text-5xl lg:text-6xl text-white font-bold leading-tight mb-6">
          El hotel más confortable de <span class="block text-primary-400">Nuevo Chimbote</span>
        </h1>
        <p class="text-base md:text-lg text-white/90 max-w-2xl mx-auto mb-8 font-light leading-relaxed">
          Hotel 3 estrellas con habitaciones confortables, desayuno, WiFi y estacionamiento. Tu mejor alojamiento en Nuevo Chimbote, Perú.
        </p>
      </div>

      <div class="flex flex-col md:flex-row gap-4 justify-center items-center animate-fade-in-up delay-200">
        <a href="/room" class="inline-flex items-center justify-center rounded-sm font-medium transition-all duration-300 uppercase tracking-widest px-10 py-4 text-base bg-primary-600 text-white hover:bg-primary-700 hover:scale-105 shadow-lg shadow-primary-500/20">
          Ver Habitaciones
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-sm font-medium transition-all duration-300 uppercase tracking-widest px-10 py-4 text-base border-2 border-white text-white hover:bg-white hover:text-dark-900">
          Contáctanos
        </a>
      </div>
    </div>
  </div>

  <!-- Immersive Experiences - pinned to bottom of hero -->
  <div class="absolute bottom-20 left-0 right-0 z-10">
    <p class="text-center text-white/50 text-[10px] md:text-xs font-medium tracking-[0.3em] uppercase mb-5">
      Explora nuestras experiencias
    </p>

    <div class="flex justify-center items-center gap-5 md:gap-8 lg:gap-10 px-6">
      {experiences.map((exp) => (
        <a
          href={exp.href}
          class="experience-pill group relative flex-shrink-0 w-[100px] h-[100px] md:w-[150px] md:h-[150px] lg:w-[190px] lg:h-[190px] overflow-hidden shadow-xl border border-white/20 hover:border-primary-400/50 transition-all duration-500 hover:scale-105"
          style="border-radius: 999px;"
          aria-label={`Explorar ${exp.title}`}
        >
          <img
            src={exp.image}
            alt={exp.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-115"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-black/35 group-hover:bg-black/15 transition-all duration-500"></div>

          <!-- Play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-8 h-8 md:w-10 md:h-10 rounded-full bg-white/20 backdrop-blur-sm border border-white/30 flex items-center justify-center group-hover:bg-white/30 group-hover:scale-110 transition-all duration-300">
              <svg class="w-3 h-3 md:w-4 md:h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>

          <!-- Label -->
          <div class="absolute bottom-2 md:bottom-3 left-0 right-0 text-center">
            <span class="text-white text-[10px] md:text-xs font-medium tracking-wider drop-shadow-lg">
              {exp.title}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-3 left-1/2 transform -translate-x-1/2 animate-bounce z-10">
    <a href="#welcome" class="text-white/40 hover:text-white transition-colors p-2" aria-label="Desplazar hacia abajo">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>
