---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  [key: string]: any;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className,
  type = 'button',
  ...rest
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center rounded-sm font-medium uppercase tracking-widest";

const variants: Record<string, string> = {
  primary: "bg-primary-600 text-white hover:bg-primary-700 hover:scale-105 shadow-lg shadow-primary-500/20",
  secondary: "bg-surface-alt text-heading border border-border hover:border-border-hover hover:scale-105",
  outline: "border-2 border-primary-500 text-primary-600 hover:bg-primary-500 hover:text-white",
  ghost: "text-body hover:text-primary-500 hover:bg-surface-alt",
};

const sizes: Record<string, string> = {
  sm: "px-4 py-2 text-xs",
  md: "px-8 py-3 text-sm",
  lg: "px-10 py-4 text-base",
};

const classes = [
  baseStyles,
  variants[variant],
  sizes[size],
  className,
].join(" ");

const Tag = href ? "a" : "button";
---

<Tag href={href} type={!href ? type : undefined} class={classes} {...rest}>
  <slot />
</Tag>
