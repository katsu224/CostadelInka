---
interface Props {
  id?: string;
  class?: string;
  background?: 'default' | 'alt' | 'dark';
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const {
  id,
  class: className,
  background = 'default',
  padding = 'lg'
} = Astro.props;

const backgrounds: Record<string, string> = {
  default: "bg-surface",
  alt: "bg-surface-alt",
  dark: "bg-dark-900 text-white",
};

const paddings: Record<string, string> = {
  none: "",
  sm: "py-12",
  md: "py-20",
  lg: "py-28",
};

const classes = [
  backgrounds[background],
  paddings[padding],
  className
].join(" ");
---

<section id={id} class={classes}>
  <div class="container mx-auto px-6">
    <slot />
  </div>
</section>
