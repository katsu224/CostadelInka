---
import "@fontsource/playfair-display/latin.css";
import "@fontsource/inter/latin.css";
import "../styles/global.css";

import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeasonalEffect from "../components/SeasonalEffect.astro";
import FloatingActions from "../components/FloatingActions.astro";

export type Theme = "default" | "christmas" | "valentine";

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  activeTheme?: Theme;
  schema?: Record<string, any> | Record<string, any>[];
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description = "Hotel Costa del Inka - Experiencia única y servicio personalizado en Nuevo Chimbote. Habitaciones modernas, restaurante, sala de eventos y más.",
  image,
  type,
  activeTheme = "default",
  schema,
  breadcrumbs,
} = Astro.props;

const themeClass = activeTheme !== "default" ? `theme-${activeTheme}` : "";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Security Headers -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.google.com https://maps.googleapis.com https://maps.gstatic.com; frame-src https://www.google.com https://www.booking.com; connect-src 'self' https://www.google-analytics.com; font-src 'self';" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Font Preloading to break critical dependency chain -->
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />

    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      schema={schema}
      breadcrumbs={breadcrumbs}
    />
    <!-- Aplicar dark-mode ANTES del primer paint para evitar flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem("hotel-theme-mode");
        if (saved === "dark") {
          document.documentElement.classList.add("is-dark");
        }
      })();
    </script>
    <style is:inline>
      .video-bg {
        transition: opacity 0.8s ease;
      }
      .video-bg.loaded {
        opacity: 1;
      }
    </style>
  </head>
  <body
    class:list={[
      "bg-surface text-body antialiased selection:bg-primary-500/30 selection:text-white flex flex-col min-h-screen",
      themeClass,
    ]}
  >
    <SeasonalEffect theme={activeTheme} />
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
    <!-- Video fade-in global -->
    <script is:inline>
      document.querySelectorAll(".video-bg").forEach(function (video) {
        function reveal() {
          video.classList.add("loaded");
        }
        if (video.readyState >= 3) {
          reveal();
        } else {
          video.addEventListener("canplay", reveal, { once: true });
        }
      });
    </script>

    <!-- Scroll Reveal Animation System -->
    <script is:inline>
      function initScrollReveal() {
        var elements = document.querySelectorAll('[data-reveal]');
        if (!elements.length) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = el.getAttribute('data-reveal-delay') || '0';
              el.style.transitionDelay = delay + 'ms';
              el.classList.add('revealed');
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        elements.forEach(function(el) { observer.observe(el); });
      }

      // Run on initial load
      initScrollReveal();

      // Re-run after View Transitions navigation
      document.addEventListener('astro:page-load', initScrollReveal);
    </script>
  </body>
</html>
