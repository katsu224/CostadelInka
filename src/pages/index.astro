---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import { rooms } from "../data/rooms-data";

const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  name: "Hotel Costa del Inka",
  description:
    "Hotel 3 estrellas en Nuevo Chimbote con habitaciones confortables, desayuno incluido, WiFi gratis y estacionamiento.",
  url: "https://www.costadelinkahotel.com",
  telephone: "+51-933-250-639",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Av. Anchoveta Mz. W2 Lt. 24-25",
    addressLocality: "Nuevo Chimbote",
    addressRegion: "Ancash",
    postalCode: "02710",
    addressCountry: "PE",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -9.0748,
    longitude: -78.5936,
  },
  starRating: {
    "@type": "Rating",
    ratingValue: "3",
  },
  priceRange: "S/ 128 - S/ 350",
  checkinTime: "14:00",
  checkoutTime: "12:00",
  amenityFeature: [
    {
      "@type": "LocationFeatureSpecification",
      name: "WiFi gratuito",
      value: true,
    },
    {
      "@type": "LocationFeatureSpecification",
      name: "Desayuno disponible",
      value: true,
    },
    {
      "@type": "LocationFeatureSpecification",
      name: "Estacionamiento",
      value: true,
    },
    { "@type": "LocationFeatureSpecification", name: "Frigobar", value: true },
    {
      "@type": "LocationFeatureSpecification",
      name: "Servicio a la habitación",
      value: true,
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.5",
    reviewCount: "127",
    bestRating: "5",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "¿Los precios incluyen IGV?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Los precios mostrados en plataformas como Booking no siempre incluyen IGV. Turistas extranjeros con pasaporte vigente están exonerados de este impuesto según ley peruana. Huéspedes nacionales pagan IGV adicional. Le informamos el precio final exacto siempre antes del check-in, sin sorpresas.",
      },
    },
    {
      "@type": "Question",
      name: "¿Puedo pagar en dólares o soles?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Aceptamos ambas monedas. El tipo de cambio del día se informa en recepción al momento del pago.",
      },
    },
    {
      "@type": "Question",
      name: "¿Tienen estacionamiento?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí contamos con estacionamiento para huéspedes. La disponibilidad es limitada — si viaja en vehículo escríbanos por WhatsApp con anticipación para reservar su espacio.",
      },
    },
    {
      "@type": "Question",
      name: "¿El desayuno está incluido en todas las habitaciones?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "El desayuno varía según el tipo de habitación y tarifa elegida. En habitaciones donde está incluido, aplica para 2 adultos.",
      },
    },
    {
      "@type": "Question",
      name: "¿Cuáles son los horarios de check-in y check-out?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Check-in desde las 2:00 pm. Check-out hasta las 12:00 pm.",
      },
    },
    {
      "@type": "Question",
      name: "¿Tienen WiFi en todas las habitaciones?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí, WiFi gratuito en todas las habitaciones y áreas comunes del hotel.",
      },
    },
    {
      "@type": "Question",
      name: "¿Puedo hacer una reserva directa sin usar Booking?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Sí. Escríbenos por WhatsApp y coordinamos su reserva directamente. Le respondemos en menos de 1 hora.",
      },
    },
  ],
};
---

<MainLayout
  title="Hotel Costa del Inka Chimbote | Hospedaje 3 Estrellas en Nuevo Chimbote"
  description="Hotel 3 estrellas en Nuevo Chimbote con habitaciones confortables, desayuno, WiFi y estacionamiento. Reserva directo o por WhatsApp. Mejor atención garantizada."
  schema={[hotelSchema, faqSchema]}
>
  <!-- Splash Screen (all inline so it renders BEFORE CSS loads) -->
  <div id="splash-screen" style="position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#1a1a1a;">
    <div id="splash-logo" style="opacity:0;text-align:center;">
      <div style="font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:700;color:#c5a572;letter-spacing:0.15em;line-height:1;">COSTA</div>
      <div style="font-family:'Playfair Display',serif;font-size:clamp(1.5rem,4vw,2.5rem);color:#fff;letter-spacing:0.3em;margin-top:-4px;line-height:1;">DEL INKA</div>
    </div>
    <div id="splash-line" style="width:64px;height:2px;background:#c5a572;margin-top:24px;transform:scaleX(0);"></div>
    <div id="splash-sub" style="opacity:0;color:rgba(255,255,255,0.7);font-family:'Inter',sans-serif;font-size:11px;letter-spacing:0.4em;text-transform:uppercase;margin-top:16px;">Hotel & Restaurant</div>
  </div>
  <script is:inline>
    (function(){
      var s = document.getElementById('splash-screen');
      if (!s) return;
      if (sessionStorage.getItem('splash-done')) { s.remove(); return; }
      sessionStorage.setItem('splash-done','1');
      // Animate in
      var logo = document.getElementById('splash-logo');
      var line = document.getElementById('splash-line');
      var sub = document.getElementById('splash-sub');
      requestAnimationFrame(function(){
        logo.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        logo.style.opacity = '1';
        logo.style.transform = 'scale(1)';
        setTimeout(function(){
          line.style.transition = 'transform 0.5s cubic-bezier(0.16,1,0.3,1)';
          line.style.transform = 'scaleX(1)';
        }, 300);
        setTimeout(function(){
          sub.style.transition = 'opacity 0.4s ease';
          sub.style.opacity = '1';
        }, 500);
        // Fade out
        setTimeout(function(){
          s.style.transition = 'opacity 0.4s ease';
          s.style.opacity = '0';
          setTimeout(function(){ s.remove(); }, 450);
        }, 1400);
      });
    })();
  </script>

  <Hero />

  <!-- ============================================
       SOBRE NOSOTROS — Premium Section
       ============================================ -->
  <section id="welcome" class="relative overflow-hidden bg-surface-alt">
    <div class="container mx-auto px-6 py-20 md:py-28">
      <!-- Top: Info + Image -->
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-20"
        data-reveal="up"
      >
        <!-- Left: Title + Highlights -->
        <div class="space-y-8">
          <div>
            <h2
              class="font-heading text-3xl md:text-4xl font-bold text-heading leading-tight mb-3"
            >
              Sobre Nosotros
            </h2>
            <div class="w-16 h-1 bg-primary-500"></div>
          </div>

          <!-- Highlights -->
          <div class="space-y-6">
            <!-- Referente Regional -->
            <div class="flex gap-5 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full border border-primary-500/30 bg-primary-500/10 flex items-center justify-center"
              >
                <svg
                  class="w-5 h-5 text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-heading font-semibold text-base mb-1">
                  Referente Regional
                </h3>
                <p class="text-muted text-sm leading-relaxed">
                  Ubicados estratégicamente en Nuevo Chimbote, nos hemos
                  convertido en referente de calidad y hospitalidad en la
                  región, combinando un trato cálido y familiar.
                </p>
              </div>
            </div>

            <!-- Hospedaje Boutique -->
            <div class="flex gap-5 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full border border-primary-500/30 bg-primary-500/10 flex items-center justify-center"
              >
                <svg
                  class="w-5 h-5 text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-heading font-semibold text-base mb-1">
                  Hospedaje Boutique
                </h3>
                <p class="text-muted text-sm leading-relaxed">
                  40 habitaciones en categorías modernas, diseñadas
                  individualmente para brindar el máximo confort con una
                  edificación moderna y acogedora.
                </p>
              </div>
            </div>

            <!-- Atención Personalizada -->
            <div class="flex gap-5 items-start">
              <div
                class="flex-shrink-0 w-12 h-12 rounded-full border border-primary-500/30 bg-primary-500/10 flex items-center justify-center"
              >
                <svg
                  class="w-5 h-5 text-primary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-heading font-semibold text-base mb-1">
                  Atención Personalizada
                </h3>
                <p class="text-muted text-sm leading-relaxed">
                  Prometemos un trato cercano para que cada huésped se sienta en
                  un ambiente cálido, con un estilo familiar que nos distingue.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Framed Image -->
        <div class="relative">
          <!-- Decorative gold corner frame -->
          <div
            class="absolute -top-3 -right-3 w-[calc(100%+6px)] h-[calc(100%+6px)] border border-primary-500/30 hidden lg:block"
            style="clip-path: polygon(60% 0, 100% 0, 100% 40%, 100% 100%, 0 100%, 0 60%, 0 0, 60% 0);"
          >
          </div>
          <div class="absolute -top-3 -right-3 hidden lg:block">
            <div class="w-20 h-[1px] bg-primary-500/60"></div>
            <div class="w-[1px] h-20 bg-primary-500/60"></div>
          </div>
          <div class="absolute -bottom-3 -left-3 hidden lg:block">
            <div class="absolute bottom-0 w-20 h-[1px] bg-primary-500/60"></div>
            <div class="absolute bottom-0 w-[1px] h-20 bg-primary-500/60"></div>
          </div>

          <img
            src="/images/rooms/habitacion-superior.webp"
            alt="Suite de lujo con vista al mar en Hotel Costa del Inka"
            class="w-full aspect-[4/3] object-cover shadow-2xl"
          />

          <!-- 40+ badge -->
          <div
            class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 bg-surface-card backdrop-blur-sm p-4 md:p-5 border border-border shadow-xl"
          >
            <p
              class="font-heading text-3xl md:text-4xl text-primary-400 font-bold leading-none"
            >
              40+
            </p>
            <p class="text-muted text-xs uppercase tracking-widest mt-1">
              Habitaciones
            </p>
          </div>
        </div>
      </div>

      <!-- Decorative corner star -->
      <div
        class="absolute bottom-8 right-8 text-primary-500/20 hidden lg:block"
      >
        <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 2l2.09 6.26L20.18 9.27l-5.09 3.96L16.18 20 12 16.77 7.82 20l1.09-6.77L3.82 9.27l6.09-1.01L12 2z"
          ></path>
        </svg>
      </div>
    </div>

    <!-- ============================================
       NUESTRAS HABITACIONES — Preview
       ============================================ -->
    <Section id="rooms">
      <div class="text-center max-w-3xl mx-auto mb-16" data-reveal="up">
        <span
          class="text-primary-700 text-sm font-bold tracking-widest uppercase mb-2 block"
          >Alojamiento</span
        >
        <h2 class="font-heading text-3xl text-heading font-bold mb-4">
          Nuestras Habitaciones
        </h2>
        <div class="w-16 h-1 bg-primary-500 mx-auto mb-6"></div>
        <p class="text-muted">
          Desde habitaciones individuales hasta opciones familiares, todas
          diseñadas para tu máximo confort.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
        data-reveal="up"
      >
        {
          rooms.slice(0, 3).map((room) => (
            <a
              href={`/rooms/${room.id}`}
              class="group block bg-surface-card border border-border rounded-xl overflow-hidden shadow-sm hover:shadow-xl hover:border-border-hover transition-all duration-300 hover:-translate-y-1"
            >
              <div class="relative h-[220px] overflow-hidden">
                <img
                  src={room.gallery[0]}
                  alt={`${room.title} Hotel Costa del Inka Nuevo Chimbote`}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute top-4 right-4 bg-black/70 backdrop-blur-sm text-white px-3 py-1.5 rounded-sm text-xs font-bold tracking-wide">
                  Desde S/ {room.priceFrom}
                </div>
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4">
                  <span class="text-white/80 text-xs font-medium tracking-wide">
                    {room.beds} · Máx. {room.maxGuests}{" "}
                    {room.maxGuests === 1 ? "huésped" : "huéspedes"}
                  </span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-heading text-lg text-heading font-bold mb-2 group-hover:text-primary-500 transition-colors">
                  {room.shortTitle}
                </h3>
                <p class="text-muted text-sm leading-relaxed line-clamp-2 mb-4">
                  {room.description}
                </p>
                <span class="text-primary-700 text-sm font-bold uppercase tracking-wider flex items-center gap-2">
                  Ver detalles{" "}
                  <span class="transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-12">
        <Button href="/room" variant="outline" size="lg"
          >Ver todas las habitaciones</Button
        >
      </div>
    </Section>

    <!-- ============================================
       NUESTROS SERVICIOS — Premium Section
       ============================================ -->
    <Section id="services">
      <div class="text-center max-w-3xl mx-auto mb-16" data-reveal="up">
        <span
          class="text-primary-700 text-sm font-bold tracking-widest uppercase mb-2 block"
          >Experiencia Completa</span
        >
        <h2 class="font-heading text-3xl text-heading font-bold mb-4">
          Nuestros Servicios
        </h2>
        <div class="w-16 h-1 bg-primary-500 mx-auto mb-6"></div>
        <p class="text-muted">
          Disfrute de una estancia inolvidable con nuestra gama completa de
          servicios diseñados para su confort y satisfacción.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal="up">
        <!-- Restaurante -->
        <div
          class="group service-card relative bg-surface-card rounded-xl border border-border overflow-hidden hover:border-border-hover hover:-translate-y-2 shadow-sm hover:shadow-xl transition-all duration-500"
        >
          <!-- Illustration Area -->
          <div
            class="relative w-full h-48 bg-icon-bg overflow-hidden flex items-center justify-center"
          >
            <!-- Decorative corner lines -->
            <div
              class="absolute top-3 left-3 w-8 h-8 border-t border-l border-primary-500/30"
            >
            </div>
            <div
              class="absolute top-3 right-3 w-8 h-8 border-t border-r border-primary-500/30"
            >
            </div>
            <div
              class="absolute bottom-3 left-3 w-8 h-8 border-b border-l border-primary-500/30"
            >
            </div>
            <div
              class="absolute bottom-3 right-3 w-8 h-8 border-b border-r border-primary-500/30"
            >
            </div>

            <!-- SVG Illustration -->
            <div
              class="relative z-10 flex items-center gap-6 text-primary-500/70 group-hover:text-primary-500 transition-colors duration-500"
            >
              <svg
                class="w-16 h-16"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="0.8"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M8 12h8M12 8v8" stroke-width="0.5"></path>
                <path
                  d="M9 7c1-2 5-2 6 0"
                  stroke-width="1"
                  stroke-linecap="round"></path>
                <line
                  x1="12"
                  y1="7"
                  x2="12"
                  y2="3"
                  stroke-width="1"
                  stroke-linecap="round"></line>
                <circle cx="12" cy="2.5" r="0.5" fill="currentColor"></circle>
              </svg>
              <svg
                class="w-12 h-12 opacity-60"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 3v2m0 14v2M5.636 5.636l1.414 1.414m9.9 9.9l1.414 1.414M3 12h2m14 0h2M5.636 18.364l1.414-1.414m9.9-9.9l1.414-1.414"
                ></path>
                <path d="M9 17h6M8 20h8" stroke-linecap="round"></path>
                <path
                  d="M6 8c0-3 3-5.5 6-5.5s6 2.5 6 5.5c0 2-1 3.5-2.5 4.5-.5.3-1 1-1 1.5v1h-5v-1c0-.5-.5-1.2-1-1.5C7 11.5 6 10 6 8z"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="p-7">
            <h3 class="font-heading text-xl text-heading font-bold mb-2">
              Restaurante
            </h3>
            <p class="text-muted text-sm mb-5 leading-relaxed">
              Variedad gastronómica local e internacional. Desayuno, almuerzo y
              cena con los mejores ingredientes.
            </p>
            <a
              href="/restaurant"
              class="text-primary-700 text-sm font-bold uppercase tracking-wider hover:text-primary-800 transition-colors flex items-center gap-2 group-hover:gap-3"
            >
              Ver mas <span
                class="transition-transform group-hover:translate-x-1">→</span
              >
            </a>
          </div>
        </div>

        <!-- Sala de Eventos -->
        <div
          class="group service-card relative bg-surface-card rounded-xl border border-border overflow-hidden hover:border-border-hover hover:-translate-y-2 shadow-sm hover:shadow-xl transition-all duration-500"
        >
          <!-- Illustration Area -->
          <div
            class="relative w-full h-48 bg-icon-bg overflow-hidden flex items-center justify-center"
          >
            <!-- Decorative corner lines -->
            <div
              class="absolute top-3 left-3 w-8 h-8 border-t border-l border-primary-500/30"
            >
            </div>
            <div
              class="absolute top-3 right-3 w-8 h-8 border-t border-r border-primary-500/30"
            >
            </div>
            <div
              class="absolute bottom-3 left-3 w-8 h-8 border-b border-l border-primary-500/30"
            >
            </div>
            <div
              class="absolute bottom-3 right-3 w-8 h-8 border-b border-r border-primary-500/30"
            >
            </div>

            <!-- SVG Illustration -->
            <div
              class="relative z-10 flex items-center gap-6 text-primary-500/70 group-hover:text-primary-500 transition-colors duration-500"
            >
              <svg
                class="w-14 h-14"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="0.8"
              >
                <rect x="2" y="6" width="20" height="14" rx="1"></rect>
                <path d="M2 6l10 7 10-7" stroke-width="0.8"></path>
                <line
                  x1="6"
                  y1="3"
                  x2="6"
                  y2="6"
                  stroke-width="1.5"
                  stroke-linecap="round"></line>
                <line
                  x1="10"
                  y1="2"
                  x2="10"
                  y2="6"
                  stroke-width="1.5"
                  stroke-linecap="round"></line>
                <line
                  x1="14"
                  y1="2"
                  x2="14"
                  y2="6"
                  stroke-width="1.5"
                  stroke-linecap="round"></line>
                <line
                  x1="18"
                  y1="3"
                  x2="18"
                  y2="6"
                  stroke-width="1.5"
                  stroke-linecap="round"></line>
              </svg>
              <svg
                class="w-16 h-16 opacity-60"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="0.8"
              >
                <path d="M4 21V8l8-5 8 5v13"></path>
                <rect x="9" y="13" width="6" height="8"></rect>
                <rect x="10.5" y="9" width="3" height="3" rx="0.5"></rect>
                <path d="M1 21h22" stroke-width="1"></path>
              </svg>
            </div>
          </div>

          <!-- Content -->
          <div class="p-7">
            <h3 class="font-heading text-xl text-heading font-bold mb-2">
              Sala de Eventos
            </h3>
            <p class="text-muted text-sm mb-5 leading-relaxed">
              Espacios equipados para conferencias, seminarios y celebraciones
              sociales con servicio integral.
            </p>
            <a
              href="/evento"
              class="text-primary-700 text-sm font-bold uppercase tracking-wider hover:text-primary-800 transition-colors flex items-center gap-2 group-hover:gap-3"
            >
              Ver mas <span
