---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Servicios Hotel Costa del Inka",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Restaurante" },
    { "@type": "ListItem", position: 2, name: "Sala de Eventos" },
    { "@type": "ListItem", position: 3, name: "Cochera Privada" },
    { "@type": "ListItem", position: 4, name: "Terrazas" },
    { "@type": "ListItem", position: 5, name: "WiFi Gratuito" },
    { "@type": "ListItem", position: 6, name: "Lavandería" },
  ],
};

const breadcrumbs = [
  { name: "Inicio", url: "/" },
  { name: "Servicios" },
];

const services = [
  {
    title: "Restaurante",
    description:
      "Disfrute de la mejor gastronomía local e internacional en un ambiente elegante.",
    icon: `<svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"></path></svg>`,
    href: "/restaurant",
    image:
      "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=2070&auto=format&fit=crop",
  },
  {
    title: "Sala de Eventos",
    description:
      "Espacios versátiles para conferencias, matrimonios y celebraciones especiales.",
    icon: `<svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"></path></svg>`,
    href: "/evento",
    image:
      "https://images.unsplash.com/photo-1519167758481-83f550bb49b3?q=80&w=2098&auto=format&fit=crop",
  },
  {
    title: "Cochera Privada",
    description:
      "Seguridad total para su vehículo dentro de nuestras instalaciones.",
    icon: `<svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path></svg>`,
    href: "/cochera",
    image:
      "https://images.unsplash.com/photo-1506521781263-d8422e82f27a?q=80&w=2070&auto=format&fit=crop",
  },
  {
    title: "Terrazas",
    description: "Áreas al aire libre con vistas panorámicas para su relax.",
    icon: `<svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"></path></svg>`,
    href: "/terraza",
    image:
      "https://images.unsplash.com/photo-1629140727571-9b5c6f6267b4?q=80&w=1854&auto=format&fit=crop",
  },
];
---

<MainLayout
  title="Servicios | Hotel Costa del Inka Chimbote | WiFi, Desayuno y Más"
  description="Descubre todos los servicios del Hotel Costa del Inka en Nuevo Chimbote: desayuno buffet, WiFi gratis, servicio a la habitación, lavandería y estacionamiento."
  schema={servicesSchema}
  breadcrumbs={breadcrumbs}
>
  <PageHeader
    title="Todo lo que necesitas durante tu estadía"
    subtitle="Servicios diseñados para hacer su estancia inolvidable"
    imageSrc="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?auto=format&fit=crop&w=1920&q=80"
  />
  <Breadcrumbs items={breadcrumbs} />

  <Section>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12" data-reveal="up">
      {
        services.map((service) => (
          <div class="group relative overflow-hidden rounded-xl bg-surface-card/95 backdrop-blur-md border border-primary-500/20 shadow-lg hover:shadow-[0_0_30px_rgba(197,165,114,0.15)] hover:border-primary-500/50 transition-all duration-500 hover:-translate-y-1">
            <div class="h-64 overflow-hidden relative">
              <img
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-900/40 to-transparent" />
            </div>
            <div class="p-8 relative">
              <div class="w-14 h-14 bg-dark-900 rounded-full flex items-center justify-center mb-6 text-primary-500 shadow-xl -mt-16 relative z-10 border border-primary-500/30">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="font-heading text-2xl text-heading font-bold mb-3">
                {service.title}
              </h3>
              <p class="text-body mb-6 leading-relaxed">
                {service.description}
              </p>
              <div class="flex items-center">
                <a
                  href={service.href}
                  class="text-primary-500 text-sm font-bold uppercase tracking-wider hover:text-primary-400 transition-colors flex items-center gap-2 group-hover:gap-3"
                >
                  Ver Detalles{" "}
                  <span class="text-lg transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <Section background="alt" padding="md">
    <div class="text-center max-w-3xl mx-auto">
      <h3 class="font-heading text-3xl text-heading font-bold mb-8">
        Servicios Adicionales
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-reveal="up" data-reveal-delay="100">
        <!-- WiFi -->
        <div
          class="group p-6 border border-primary-500/10 rounded-xl bg-surface-card/60 backdrop-blur-sm hover:text-white hover:bg-dark-900 hover:border-primary-500/40 shadow-sm hover:shadow-lg transition-all duration-300"
        >
          <div
            class="w-12 h-12 mx-auto bg-primary-500/10 text-primary-400 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-primary-500/20 transition-transform"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"
              ></path></svg
            >
          </div>
          <span
            class="text-heading group-hover:text-white transition-colors duration-300 font-bold block mb-1"
            >WiFi Gratis</span
          >
          <span
            class="text-body group-hover:text-gray-200 transition-colors duration-300 text-xs"
            >Alta velocidad</span
          >
        </div>
        <!-- Café -->
        <div
          class="group p-6 border border-primary-500/10 rounded-xl bg-surface-card/60 backdrop-blur-sm hover:bg-dark-900 hover:border-primary-500/40 shadow-sm hover:shadow-lg transition-all duration-300"
        >
          <div
            class="w-12 h-12 mx-auto bg-primary-500/10 text-primary-400 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-primary-500/20 transition-transform"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15 3.75H9m3 0v16.5m0-16.5V3.75a3 3 0 00-3 3v8.25a3 3 0 003 3h3a3 3 0 003-3V6.75a3 3 0 00-3-3z"
              ></path></svg
            >
          </div>
          <span
            class="text-heading group-hover:text-white transition-colors duration-300 font-bold block mb-1"
            >Café & Té</span
          >
          <span
            class="text-body group-hover:text-gray-200 transition-colors duration-300 text-xs"
            >Cortesía en lobby</span
          >
        </div>
        <!-- Amenities -->
        <div
          class="group p-6 border border-primary-500/10 rounded-xl bg-surface-card/60 backdrop-blur-sm hover:bg-dark-900 hover:border-primary-500/40 shadow-sm hover:shadow-lg transition-all duration-300"
        >
          <div
            class="w-12 h-12 mx-auto bg-primary-500/10 text-primary-400 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-primary-500/20 transition-transform"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
          </div>
          <span
            class="text-heading group-hover:text-white transition-colors duration-300 font-bold block mb-1"
            >Amenities</span
          >
          <span
            class="text-body group-hover:text-gray-200 transition-colors duration-300 text-xs"
            >Premium included</span
          >
        </div>
        <!-- Limpieza -->
        <div
          class="group p-6 border border-primary-500/10 rounded-xl bg-surface-card/60 backdrop-blur-sm hover:bg-dark-900 hover:border-primary-500/40 shadow-sm hover:shadow-lg transition-all duration-300"
        >
          <div
            class="w-12 h-12 mx-auto bg-primary-500/10 text-primary-400 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 group-hover:bg-primary-500/20 transition-transform"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
              ></path></svg
            >
          </div>
          <span
            class="text-heading group-hover:text-white transition-colors duration-300 font-bold block mb-1"
            >Limpieza</span
          >
          <span
            class="text-body group-hover:text-gray-200 transition-colors duration-300 text-xs"
            >Diaria</span
          >
        </div>
      </div>
    </div>
  </Section>
</MainLayout>
