---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";

const breadcrumbs = [
  { name: "Inicio", url: "/" },
  { name: "Servicios", url: "/service" },
  { name: "Terrazas" },
];
---

<MainLayout
  title="Terrazas | Hotel Costa del Inka Nuevo Chimbote"
  description="Relájate en las terrazas del Hotel Costa del Inka con vistas panorámicas en Nuevo Chimbote. Espacios al aire libre para disfrutar durante tu estadía."
  breadcrumbs={breadcrumbs}
>
  <PageHeader
    title="Nuestras Terrazas"
    subtitle="Espacios al aire libre para relajarse y disfrutar"
    imageSrc="/images/services/terraza-header.webp"
    imageSrcMobile="/images/thumbs/terraza-header-sm.webp"
  />
  <Breadcrumbs items={breadcrumbs} />

  <!-- Intro -->
  <Section>
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal="up">
      <h2 class="font-heading text-3xl text-heading font-bold mb-6">
        Relax con Vista Panorámica
      </h2>
      <p class="text-body leading-relaxed text-lg">
        Disfrute de nuestras amplias terrazas, ideales para tomar un café por la mañana, leer
        un libro por la tarde o simplemente contemplar la vista panorámica de Nuevo Chimbote
        mientras el sol se pone.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12" data-reveal="up" data-reveal-delay="100">
      <div class="relative group overflow-hidden rounded-sm h-80 shadow-lg">
        <img
          src="/images/services/desayuno-buffet.webp"
          alt="Terraza lounge Hotel Costa del Inka"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent flex items-end p-8"
        >
          <div>
            <h3 class="font-heading text-2xl text-white font-bold">Zona Lounge</h3>
            <p class="text-white/70 text-sm mt-1">Mobiliario cómodo para descansar y conversar</p>
          </div>
        </div>
      </div>
      <div class="relative group overflow-hidden rounded-sm h-80 shadow-lg">
        <img
          src="/images/hotel/recepcion-hotel.webp"
          alt="Vista panorámica desde la terraza"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-dark-900/80 to-transparent flex items-end p-8"
        >
          <div>
            <h3 class="font-heading text-2xl text-white font-bold">Vistas Panorámicas</h3>
            <p class="text-white/70 text-sm mt-1">Disfrute de la ciudad desde las alturas</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Qué puede hacer -->
  <Section background="alt">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="font-heading text-3xl text-heading font-bold mb-4">
        Actividades en la Terraza
      </h2>
      <p class="text-muted leading-relaxed">
        Nuestras terrazas son espacios versátiles diseñados para su comodidad en cualquier momento del día.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8" data-reveal="up" data-reveal-delay="200">
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Desayuno al Aire Libre</h3>
        <p class="text-muted text-sm">Comience su día con un café y la brisa matutina de la costa</p>
      </div>
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Lectura y Relax</h3>
        <p class="text-muted text-sm">Ambiente tranquilo ideal para desconectarse y disfrutar un buen libro</p>
      </div>
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Fotos y Atardeceres</h3>
        <p class="text-muted text-sm">Capture los mejores momentos con vistas espectaculares de fondo</p>
      </div>
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Reuniones Casuales</h3>
        <p class="text-muted text-sm">Espacio perfecto para conversar con amigos o colegas al aire libre</p>
      </div>
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Trabajo Remoto</h3>
        <p class="text-muted text-sm">WiFi disponible para trabajar con la mejor vista de oficina posible</p>
      </div>
      <div class="bg-surface-card p-8 rounded-sm border border-border text-center hover:shadow-lg transition-all">
        <div class="w-14 h-14 mx-auto bg-primary-500/10 rounded-full flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        </div>
        <h3 class="font-heading text-lg text-heading font-bold mb-2">Momentos Románticos</h3>
        <p class="text-muted text-sm">Atardeceres inolvidables en pareja con ambiente íntimo</p>
      </div>
    </div>
  </Section>

  <!-- Detalles -->
  <Section padding="md">
    <div class="max-w-3xl mx-auto bg-surface-card border border-border rounded-sm p-8 md:p-12">
      <h3 class="font-heading text-2xl text-heading font-bold mb-6 text-center">
        Detalles de las Terrazas
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <p class="font-heading text-3xl text-primary-500 font-bold">24h</p>
          <p class="text-muted text-sm mt-1">Acceso libre para huéspedes</p>
        </div>
        <div>
          <p class="font-heading text-3xl text-primary-500 font-bold">360°</p>
          <p class="text-muted text-sm mt-1">Vistas panorámicas de la ciudad</p>
        </div>
        <div>
          <p class="font-heading text-3xl text-primary-500 font-bold">WiFi</p>
          <p class="text-muted text-sm mt-1">Conexión disponible en toda el área</p>
        </div>
      </div>
      <div class="text-center mt-8">
        <Button href="/room">Reservar Habitación</Button>
      </div>
    </div>
  </Section>
</MainLayout>
